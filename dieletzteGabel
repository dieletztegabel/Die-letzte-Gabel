
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meine Website</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: #a51515;
            line-height: 1.6;
        }

        header {
            background: #222;
            color: white;
            padding: 20px 0;
        }

        .container {
            width: 90%;
            max-width: 1200px;
            margin: auto;
        }

        .logo {
            float: left;
            font-size: 24px;
            font-weight: bold;
        }

        nav {
            float: right;
        }

        nav ul {
            list-style: none;
        }

        nav ul li {
            display: inline;
            margin-left: 20px;
        }

        nav ul li a {
            color: white;
            text-decoration: none;
        }

        .hero {
            background: #0077ff;
            color: white;
            padding: 80px 20px;
            text-align: center;
        }

        .main {
            display: flex;
            gap: 20px;
            margin: 40px 0;
        }

        .content {
            flex: 3;
            background: white;
            padding: 20px;
            border-radius: 5px;
        }

        .sidebar {
            flex: 1;
            background: white;
            padding: 20px;
            border-radius: 5px;
        }

        footer {
            background: #222;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: 40px;
        }

        /* Responsive */
        @media(max-width: 768px) {
            .main {
                flex-direction: column;
            }

            .logo, nav {
                float: none;
                text-align: center;
            }

            nav ul li {
                display: block;
                margin: 10px 0;
            }
        }
    </style>
</head>
<body>

<header>
    <div class="container">
        <div class="logo">MeinLogo</div>
        <nav>
            <ul>
                <li><a href="#">Start</a></li>
                <li><a href="#">Über uns</a></li>
                <li><a href="#">Leistungen</a></li>
                <li><a href="#">Kontakt</a></li>
            </ul>
        </nav>
        <div style="clear: both;"></div>
    </div>
</header>

<section class="hero">
    <h1>Willkommen auf meiner Website</h1>
    <p>Hier steht ein kurzer Einführungstext.</p>
</section>

<div class="container">
    <div class="main">
        <div class="content">
            <h2>Hauptinhalt</h2>
            <p>
                Hier steht dein Hauptcontent. Texte, Bilder, Videos oder andere Inhalte.
            </p>
        </div>

        <aside class="sidebar">
            <h3>Sidebar</h3>
            <p>Zusätzliche Informationen oder Links.</p>
        </aside>
    </div>
</div>

<footer>
    <p>&copy; 2026 Meine Website | Impressum | Datenschutz</p>
</footer>

</body>
</html>